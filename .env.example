# ===== Supabase =====
# Projeto: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — NUNCA expor no cliente
SUPABASE_SERVICE_ROLE_KEY=

# ===== Google OAuth (conexões Search Console / GA4) =====
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Redirect URI autorizado: {NEXT_PUBLIC_SITE_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== App =====
# Local: http://localhost:3000 | Produção: https://os.aude...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chave de criptografia dos tokens (AES-256-GCM)
# Gerar com: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ===== Resend (convite de cliente) =====
RESEND_API_KEY=
RESEND_FROM="AUDE <contato@seudominio.com>"
